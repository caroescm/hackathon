# Supabase — obtener en https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq AI — obtener en https://console.groq.com/keys
GROQ_API_KEY=

# WhatsApp Business API (Meta) — opcional
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_TOKEN=

# Número público de WhatsApp del INEN (formato internacional, ej: 51912345678)
NEXT_PUBLIC_WHATSAPP_NUMERO=
